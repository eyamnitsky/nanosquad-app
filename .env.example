NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
BACKEND_PORT=8000
UI_PORT=3000

# Optional override for managed env-file location.
# Default: ~/.nemoclaw/config/env.local
# AGENTPLATFORM_ENV_LOCAL_PATH=/absolute/path/to/env.local

# Model provider abstraction
MODEL_PROVIDER=openrouter

# Provider/API keys
OPENROUTER_API_KEY=
OPENROUTER_HTTP_REFERER=http://localhost:3000
OPENROUTER_X_TITLE=NemoClaw Control
TELEGRAM_BOT_TOKEN=
BRAVE_SEARCH_API_KEY=

# NemoClaw integration
NEMOCLAW_CLI_PATH=
# Optional template for skill invocation.
# Example: "{skill} --task {task}"
NEMOCLAW_SKILL_TEMPLATE={skill} --task {task}

# Optional: when true, managed env vars are mirrored to ~/.zshrc
AGENTPLATFORM_SYNC_ZSHRC=false
